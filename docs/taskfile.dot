digraph {
  "build" [
    color="black"
    label="{build | Build everything}"
    shape="Mrecord"
  ]
  "build" -> "build_bin" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "build_bin" [
    color="black"
    fillcolor="lightblue"
    label="{build:bin | Build the task-graph \nbinary}"
    shape="Mrecord"
    style="filled"
  ]
  "build_bin" -> "build_dir" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "build_dir" [
    color="black"
    fillcolor="lightblue"
    label="{build:dir | Ensure our output folder exists \nand is empty}"
    shape="Mrecord"
    style="filled"
  ]
  
  "build_sbom" [
    color="black"
    fillcolor="lightblue"
    label="{build:sbom | Generate a \nsoftware-bill-of-materials (SBOM)}"
    shape="Mrecord"
    style="filled"
  ]
  "build_sbom" -> "build_bin" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "ci" [
    color="black"
    label="{ci | Run continuous integration \ntasks}"
    shape="Mrecord"
  ]
  "ci" -> "test" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  "ci" -> "build_sbom" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "default" [
    color="black"
    label="{default | Run all tasks}"
    shape="Mrecord"
  ]
  "default" -> "build" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  "default" -> "test" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "docs" [
    color="black"
    label="{docs | Generate documentation}"
    shape="Mrecord"
  ]
  "docs" -> "docs_build" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "docs_build" [
    color="black"
    fillcolor="lightgreen"
    label="{docs:build | Document the Taskfile graph and \ngenerate an image}"
    shape="Mrecord"
    style="filled"
  ]
  "docs_build" -> "build" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "gremlins" [
    color="black"
    label="{gremlins | Use gremlins to check the quality \nof our tests}"
    shape="Mrecord"
  ]
  
  "lint" [
    color="black"
    label="{lint | Run golangci-lint to check for \nlinting issues}"
    shape="Mrecord"
  ]
  
  "samples" [
    color="black"
    label="{samples | Generate graphs and images for the \nsample taskfiles}"
    shape="Mrecord"
  ]
  "samples" -> "build" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "test" [
    color="black"
    label="{test | Run tests and checks}"
    shape="Mrecord"
  ]
  "test" -> "unit-test" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  "test" -> "lint" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "tidy" [
    color="black"
    label="{tidy | Tidy up source}"
    shape="Mrecord"
  ]
  "tidy" -> "tidy_gofumpt" [
    color="blue"
    penwidth="1"
    style="dashed"
  ]
  "tidy" -> "tidy_mod" [
    color="blue"
    penwidth="1"
    style="dashed"
  ]
  "tidy" -> "tidy_lint" [
    color="blue"
    penwidth="1"
    style="dashed"
  ]
  
  "tidy_gofumpt" [
    color="black"
    fillcolor="lightyellow"
    label="{tidy:gofumpt | Run gofumpt to reformat \nsource code}"
    shape="Mrecord"
    style="filled"
  ]
  
  "tidy_lint" [
    color="black"
    fillcolor="lightyellow"
    label="{tidy:lint | Run golangci-lint in fix \nmode}"
    shape="Mrecord"
    style="filled"
  ]
  
  "tidy_mod" [
    color="black"
    fillcolor="lightyellow"
    label="{tidy:mod | Run go mod tidy}"
    shape="Mrecord"
    style="filled"
  ]
  
  "unit-test" [
    color="black"
    label="{unit-test | Run unit tests}"
    shape="Mrecord"
  ]
  "unit-test" -> "build" [
    color="black"
    penwidth="1"
    style="solid"
  ]
  
  "update-golden-files" [
    color="black"
    label="{update-golden-files | Update golden files with \ncurrent output}"
    shape="Mrecord"
  ]
  
}
